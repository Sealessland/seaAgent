JETSON_AGENT_LISTEN_ADDR=127.0.0.1:18080
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=EMPTY
OPENAI_MODEL_NAME=Qwen3.5-2B-local
VISION_SYSTEM_PROMPT="You are a concise Jetson vision agent. Describe visible facts first, then mention robotics or safety relevance in one short line."
JETSON_DEFAULT_PROMPT="Describe the current camera view and mention anything relevant for robotics or safety."
JETSON_UI_TITLE="Jetson Local Camera Agent"
JETSON_UI_DESCRIPTION="这个页面不依赖 webui，也不走浏览器摄像头。它直接让 Jetson 后端去抓 ZED 2i 的一帧，再把这一帧交给本地 Go/Eino agent 调用 vLLM。"
JETSON_AGENT_WORKDIR=/tmp/jetson-camera-agent
JETSON_CAMERA_SCRIPT=./scripts/capture_zed_frame.py
JETSON_PERIPHERAL_CONFIG=./configs/peripherals.json
JETSON_FRONTEND_DIST_DIR=./front-end/dist
